// Flash DO function - Save running parameters to EEPROM
void OnFlashDo()
{
    message 0x20 flash_msg;  // ID 32 (0x20) according to DBC
    
    flash_msg.dlc = 1;  // DBC shows 1 byte length
    flash_msg.id = 0x20;
    flash_msg.byte(0) = 0x01;  // Flash command according to DBC: 0x01=µē¦ĶĪīFlashõ┐ØÕŁś
    
    output(flash_msg);  // Send Flash DO on CAN1 (parameter control channel)
    write("[FLASH] Flash DO command sent (ID=0x20) on CAN1 - Saving parameters to EEPROM");
}

// Sleep/Wakeup function - Send control mode command on CAN2 (public CAN)
void OnSleepWakeup()
{
    message 0x1E0 control_msg;  // Control mode command frame (DBC: CONTROL_MODE_CMD)
    
    control_msg.dlc = 1;
    
    if (@MotorControl::BtnSleepWakeup == 1) {
        // Send sleep command (Stop mode)
        control_msg.byte(0) = 0x0F;  // 0x0F = Stop mode (Sleep)
        output(control_msg);
        write("[SLEEP](0x0F) via CAN2 (ID=0x1E0)");
    } else {
        // Send wakeup command (JWD loop mode)
        control_msg.byte(0) = 0x0D;  // 0x0D = JWD loop mode (Wakeup)
        output(control_msg);
        write("[WAKEUP]via CAN2 (ID=0x1E0)");
    }
}

// Parameter Feedback Control function - DBC: FEEDBACK_CONTROL_CMD (ID 0x60)
void OnParameterFeedback()
{
    message 0x60 feedback_msg;  // Feedback control command frame
    
    feedback_msg.dlc = 2;  // DBC shows 2 bytes length
    feedback_msg.id = 0x60;
    
    if (feedback_enabled == 1) {
        // Start high frequency feedback (1ms interval)
        feedback_msg.byte(0) = 0x01;  // OpCode: 0x01 = start feedback
        feedback_msg.byte(1) = 0xFF;  // SelectCode: any value (system sends all types)
        output(feedback_msg);
        write("[FEEDBACK]ID=0x60");
    } else {
        // Stop feedback
        feedback_msg.byte(0) = 0x00;  // OpCode: 0x00 = stop feedback
        feedback_msg.byte(1) = 0x00;  // SelectCode: any value
        output(feedback_msg);
        write("[FEEDBACK] Õģ│ķŚŁÕÅéµĢ░ÕÅŹķ”ł ID=0x60");
    }
}

// Version Query function - DBC: VERSION_QUERY_CMD (ID 0xA0)
void OnVersionQuery()
{
    message 0xA0 version_msg;  // Version query command frame
    
    version_msg.dlc = 1;  // DBC shows 1 byte length
    version_msg.id = 0xA0;
    version_msg.byte(0) = 0x05;  // QueryCode: 0x05 = query version info
    
    output(version_msg);
    write("[VERSION] ID=0xA0, QueryCode=0x05");
}

// Error Query Timer function - DBC: ERROR_QUERY_CMD (ID 0x80)
void sendErrorQuery()
{
    message 0x80 error_msg;  // Error query command frame
    
    error_msg.dlc = 1;  // DBC shows 1 byte length
    error_msg.id = 0x80;
    error_msg.byte(0) = 0x04;  // QueryCode: 0x04 = query fault status
    
    output(error_msg);
    write("[ERROR_QUERY] ID=0x80, QueryCode=0x04");
}

// Load current values into input variables (for Panel initialization)
void OnLoadCurrentValues()
{
    input_current_kp = current_kp;
    input_current_ki = current_ki;
    input_speed_kp = speed_kp;
    input_speed_ki = speed_ki;
    input_position_kp = position_kp;
    input_position_ki = position_ki;
    input_fieldweakening_kp = fieldweakening_kp;
    input_fieldweakening_ki = fieldweakening_ki;
    input_iq_ref = iq_ref;
    input_speed_ref = speed_ref;
    input_position_ref = position_ref;
    input_voltage_protection = voltage_protection;
    input_current_protection = current_protection;
    
    // Update system variables for Panel
    @MotorControl::InputCurrentKp = input_current_kp;
    @MotorControl::InputCurrentKi = input_current_ki;
    @MotorControl::InputSpeedKp = input_speed_kp;
    @MotorControl::InputSpeedKi = input_speed_ki;
    @MotorControl::InputPositionKp = input_position_kp;
    @MotorControl::InputPositionKi = input_position_ki;
    @MotorControl::InputFieldWeakeningKp = input_fieldweakening_kp;
    @MotorControl::InputFieldWeakeningKi = input_fieldweakening_ki;
    @MotorControl::InputIqRef = input_iq_ref;
    @MotorControl::InputSpeedRef = input_speed_ref;
    @MotorControl::InputPositionRef = input_position_ref;
    @MotorControl::InputVoltageProtection = input_voltage_protection;
    @MotorControl::InputCurrentProtection = input_current_protection;
    
    write("[PANEL] Values loaded");
}

// Batch parameter modification functions
void OnModifyAllCurrentParams()
{
    if(input_current_kp >= 0.0 && input_current_kp <= 10.0 && 
       input_current_ki >= 0.0 && input_current_ki <= 1.0) {
        write("[BATCH] Current parameters");
        modifyParameter(0xA1, input_current_kp);
        setTimer(modify_timer, 100);
        modify_param_code = 0xA2;
        modify_value = input_current_ki;
    } else {
        write("[ERROR] Current parameters out of range");
    }
}

void OnModifyAllSpeedParams()
{
    if(input_speed_kp >= 0.0 && input_speed_kp <= 10.0 && 
       input_speed_ki >= 0.0 && input_speed_ki <= 1.0) {
        write("[BATCH] Speed parameters");
        modifyParameter(0xB1, input_speed_kp);
        setTimer(modify_timer, 100);
        modify_param_code = 0xB2;
        modify_value = input_speed_ki;
    } else {
        write("[ERROR] Speed parameters out of range");
    }
}

void OnModifyAllPositionParams()
{
    if(input_position_kp >= 0.0 && input_position_kp <= 10.0 && 
       input_position_ki >= 0.0 && input_position_ki <= 1.0) {
        write("[BATCH] Position parameters");
        modifyParameter(0xC1, input_position_kp);
        setTimer(modify_timer, 100);
        modify_param_code = 0xC2;
        modify_value = input_position_ki;
    } else {
        write("[ERROR] Position parameters out of range");
    }
}

// Timers for parameter modification
on timer modify_timer
{
    // Send remaining modification commands (2nd and 3rd)
    if(modify_send_count < 3) {
        message 0x40 repeat_msg;
        
        // Reconstruct the stored message
        repeat_msg.dlc = 8;
        repeat_msg.id = 0x40;
        repeat_msg.byte(0) = stored_param_code;
        repeat_msg.byte(1) = 0x01;  // Write flag
        repeat_msg.byte(2) = stored_byte2;
        repeat_msg.byte(3) = stored_byte3;
        repeat_msg.byte(4) = stored_byte4;
        repeat_msg.byte(5) = stored_byte5;
        repeat_msg.byte(6) = 0x00;
        repeat_msg.byte(7) = 0x00;
        
        output(repeat_msg);  // Send on CAN1 for parameter modifications
        modify_send_count++;
        write("[MODIFY] Parameter 0x%02X sent (%d/3) on CAN1", stored_param_code, modify_send_count);
        
        if(modify_send_count < 3) {
            // Schedule next send
            setTimer(modify_timer, 30);  // 30ms interval
        } else {
            // All 3 commands sent
            write("[MODIFY] Parameter 0x%02X - all commands sent", stored_param_code);
        }
    }
    
    // Handle batch modification (legacy code for Panel interface)
    if(modify_param_code != 0) {
        modifyParameter(modify_param_code, modify_value);
        modify_param_code = 0;
        modify_value = 0.0;
    }
}

// Error query timer - sends fault code query every 200ms when enabled
on timer error_query_timer
{
    if(error_query_enabled == 1) {
        sendErrorQuery();
        setTimer(error_query_timer, 200);  // Query every 200ms
    }
}

// Button monitoring timer - checks for Panel button presses
on timer button_monitor_timer
{
    // Check for button presses and reset them after triggering
    if(@MotorControl::BtnModifyCurrentKp == 1) {
        @MotorControl::BtnModifyCurrentKp = 0;  // Reset button
        OnModifyCurrentKp();
    }
    
    if(@MotorControl::BtnModifyCurrentKi == 1) {
        @MotorControl::BtnModifyCurrentKi = 0;  // Reset button
        OnModifyCurrentKi();
    }
    
    if(@MotorControl::BtnModifySpeedKp == 1) {
        @MotorControl::BtnModifySpeedKp = 0;  // Reset button
        OnModifySpeedKp();
    }
    
    if(@MotorControl::BtnModifySpeedKi == 1) {
        @MotorControl::BtnModifySpeedKi = 0;  // Reset button
        OnModifySpeedKi();
    }
    
    if(@MotorControl::BtnModifyPositionKp == 1) {
        @MotorControl::BtnModifyPositionKp = 0;  // Reset button
        OnModifyPositionKp();
    }
    
    if(@MotorControl::BtnModifyPositionKi == 1) {
        @MotorControl::BtnModifyPositionKi = 0;  // Reset button
        OnModifyPositionKi();
    }
    
    if(@MotorControl::BtnModifyFieldWeakeningKp == 1) {
        @MotorControl::BtnModifyFieldWeakeningKp = 0;  // Reset button
        OnModifyFieldWeakeningKp();
    }
    
    if(@MotorControl::BtnModifyFieldWeakeningKi == 1) {
        @MotorControl::BtnModifyFieldWeakeningKi = 0;  // Reset button
        OnModifyFieldWeakeningKi();
    }
    
    if(@MotorControl::BtnModifyIqRef == 1) {
        @MotorControl::BtnModifyIqRef = 0;  // Reset button
        OnModifyIqRef();
    }
    
    if(@MotorControl::BtnModifySpeedRef == 1) {
        @MotorControl::BtnModifySpeedRef = 0;  // Reset button
        OnModifySpeedRef();
    }
    
    if(@MotorControl::BtnModifyPositionRef == 1) {
        @MotorControl::BtnModifyPositionRef = 0;  // Reset button
        OnModifyPositionRef();
    }
    
    if(@MotorControl::BtnModifyVoltageProtection == 1) {
        @MotorControl::BtnModifyVoltageProtection = 0;  // Reset button
        OnModifyVoltageProtection();
    }
    
    if(@MotorControl::BtnModifyCurrentProtection == 1) {
        @MotorControl::BtnModifyCurrentProtection = 0;  // Reset button
        OnModifyCurrentProtection();
    }
    
    if(@MotorControl::BtnFlashDo == 1) {
        @MotorControl::BtnFlashDo = 0;  // Reset button
        OnFlashDo();
    }
    
    if(@MotorControl::BtnSleepWakeup == 1) {
        @MotorControl::BtnSleepWakeup = 0;  // Reset button
        OnSleepWakeup();
    }
    
    if(@MotorControl::BtnQueryAll == 1) {
        @MotorControl::BtnQueryAll = 0;  // Reset button
        OnQueryAll();
    }
    
    if(@MotorControl::BtnLoadCurrentValues == 1) {
        @MotorControl::BtnLoadCurrentValues = 0;  // Reset button
        OnLoadCurrentValues();
    }
    
    if(@MotorControl::BtnParameterFeedback == 1) {
        @MotorControl::BtnParameterFeedback = 0;  // Reset button
        feedback_enabled = 1 - feedback_enabled;
        @MotorControl::FeedbackEnabled = feedback_enabled;
        OnParameterFeedback();
    }
    
    if(@MotorControl::BtnErrorQuery == 1) {
        @MotorControl::BtnErrorQuery = 0;  // Reset button
        error_query_enabled = 1 - error_query_enabled;
        @MotorControl::ErrorQueryEnabled = error_query_enabled;
        if(error_query_enabled != 0) {
            setTimer(error_query_timer, 200);
        } else {
            cancelTimer(error_query_timer);
        }
    }
    
    if(@MotorControl::BtnVersionQuery == 1) {
        @MotorControl::BtnVersionQuery = 0;  // Reset button
        OnVersionQuery();
    }
    
    setTimer(button_monitor_timer, 100);  // Check again in 100ms
}

// Function to sync input variables from system variables (for Panel integration)
void OnSyncInputVariables()
{
    input_current_kp = @MotorControl::InputCurrentKp;
    input_current_ki = @MotorControl::InputCurrentKi;
    input_speed_kp = @MotorControl::InputSpeedKp;
    input_speed_ki = @MotorControl::InputSpeedKi;
    input_position_kp = @MotorControl::InputPositionKp;
    input_position_ki = @MotorControl::InputPositionKi;
    input_fieldweakening_kp = @MotorControl::InputFieldWeakeningKp;
    input_fieldweakening_ki = @MotorControl::InputFieldWeakeningKi;
    input_iq_ref = @MotorControl::InputIqRef;
    input_speed_ref = @MotorControl::InputSpeedRef;
    input_position_ref = @MotorControl::InputPositionRef;
    input_voltage_protection = @MotorControl::InputVoltageProtection;
    input_current_protection = @MotorControl::InputCurrentProtection;
    
    write("[PANEL] Variables synced");
}
